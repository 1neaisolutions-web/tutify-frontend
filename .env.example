# =============================================================================
# Copy to `.env` and set values yourself. Do not commit `.env`.
# =============================================================================

# Backend base URL (no trailing slash). Example shape: http://127.0.0.1:8000
VITE_API_BASE_URL=https://web-production-f4110.up.railway.app

# API prefix URL (must end with /api). Example shape: http://127.0.0.1:8000/api
VITE_API_URL=https://web-production-f4110.up.railway.app/api

# Vite dev: where to proxy /api (see vite.config.ts). Example shape: http://127.0.0.1:8000
# VITE_PROXY_TARGET=

# Optional; see src/config/api.ts
# VITE_USE_LOCAL=

# Learning Hub personalization (must be the string true or false)
VITE_PERSONALIZATION_ENABLED=

# Temporary deployment lock for preferences (keep feature code, disable behavior).
# When true: force Language=en-US and Theme=light, disable system auto-detection.
VITE_LOCK_PREFERENCES=false
